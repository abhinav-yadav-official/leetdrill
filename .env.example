# Copy to .env and fill in.
LEETDRILL_ADDR=:8080
DATABASE_URL=postgres://leetdrill:leetdrill@localhost:5433/leetdrill?sslmode=disable

# 32-byte base64 key for AES-GCM cookie vault.
# Generate: openssl rand -base64 32
LEETDRILL_COOKIE_KEY=

# Single-user self-host mode: skip auth, hardcode this leetcode username.
SINGLE_USER=true
LEETCODE_USERNAME=

# Set false to disable 30-minute public recent-AC sync.
LEETDRILL_SYNC_WORKER=true

# Full public URL used in email links (multi-user mode only).
# Example: https://leetdrill.example.com
LEETDRILL_APP_BASE=

# SMTP settings for transactional email (multi-user mode only).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
