{
  "manifest_version": 3,
  "name": "LeetDrill Companion",
  "short_name": "LeetDrill",
  "version": "0.1.10",
  "description": "Companion for abhiy.xyz/leetdrill. Captures LeetCode submissions and syncs cookies for your practice tracker.",
  "permissions": ["alarms", "cookies", "storage"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://abhiy.xyz/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["compat.js", "content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://abhiy.xyz/leetdrill/extension/connect*"],
      "js": ["compat.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetDrill",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
